# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=webshop
DB_USER=webshop_user
DB_PASSWORD=webshop_password

# Auth
SESSION_SECRET=replace_me_with_long_random_secret
JWT_SECRET=replace_me_with_long_random_secret

# Mail (Maildev - kein Login noetig, faengt Mails lokal ab statt sie zu versenden)
SMTP_HOST=maildev
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@webshop.local

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api
