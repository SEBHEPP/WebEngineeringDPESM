# Vorlage fuer die echte Produktions-Konfiguration.
# Kopieren nach backend/.env.production (ist per .gitignore ausgeschlossen,
# damit echte Secrets nie ins Git-Repo gelangen) und dort die Platzhalter ersetzen.

# Server
NODE_ENV=production
PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=webshop
DB_USER=webshop_user
DB_PASSWORD=webshop_password

# Auth - lange Zufallswerte erzeugen: openssl rand -hex 32
SESSION_SECRET=replace_me_with_long_random_secret
JWT_SECRET=replace_me_with_long_random_secret

# Mail (Strato SMTP)
SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@gentlemanshop.sebastian-hepp.com
SMTP_PASSWORD=replace_me
SMTP_FROM=noreply@gentlemanshop.sebastian-hepp.com

# App
APP_BASE_URL=https://gentlemanshop.sebastian-hepp.com
API_BASE_URL=https://gentlemanshop.sebastian-hepp.com/api
